{
  "skill_id": "logic_chain_reducer_v1",
  "description": "Compress reasoning chains to minimal valid steps while preserving logical correctness",
  "trigger_pattern": ["therefore", "thus", "hence", "consequently", "implies", "if-then", "deduce"],
  "action_template": "Identify redundant reasoning steps; output minimal valid chain with confidence",
  "input_schema": {
    "premises": ["string"],
    "goal": "string"
  },
  "output_schema": {
    "minimal_chain": ["string"],
    "redundant_steps_removed": "integer",
    "confidence": "float (0.0-1.0)",
    "logical_validity": "boolean"
  },
  "validation_tests": [
    {
      "input": {
        "premises": ["All humans are mortal", "Socrates is human", "Socrates is Socrates"],
        "goal": "Socrates is mortal"
      },
      "expected": {
        "minimal_chain": ["All humans are mortal", "Socrates is human", "Therefore Socrates is mortal"],
        "redundant_steps_removed": 0,
        "logical_validity": true
      },
      "passed": true
    },
    {
      "input": {
        "premises": ["If rain then wet", "If wet then slippery", "It rained"],
        "goal": "It is slippery"
      },
      "expected": {
        "minimal_chain": ["If rain then wet", "If wet then slippery", "It rained", "Therefore it is slippery"],
        "redundant_steps_removed": 0,
        "logical_validity": true
      },
      "passed": true
    },
    {
      "input": {
        "premises": ["A implies B", "B implies C", "C implies D", "A"],
        "goal": "D"
      },
      "expected": {
        "minimal_chain": ["A implies B", "B implies C", "C implies D", "A", "Therefore D"],
        "redundant_steps_removed": 0,
        "logical_validity": true
      },
      "passed": true
    },
    {
      "input": {
        "premises": ["Some birds fly", "Penguin is bird"],
        "goal": "Penguin flies"
      },
      "expected": {
        "minimal_chain": ["Some birds fly", "Penguin is bird", "Cannot deduce: 'some' doesn't mean all"],
        "redundant_steps_removed": 0,
        "logical_validity": false
      },
      "passed": true
    },
    {
      "input": {
        "premises": ["All A are B", "All B are C"],
        "goal": "All A are C"
      },
      "expected": {
        "minimal_chain": ["All A are B", "All B are C", "Therefore all A are C"],
        "redundant_steps_removed": 0,
        "logical_validity": true
      },
      "passed": true
    }
  ],
  "metrics": {
