{
  "skill_id": "bug_predictor_v1",
  "description": "Predict common bug patterns in Python code based on syntactic and semantic features",
  "trigger_pattern": ["def ", "class ", "import ", "try:", "except", "if ", "for ", "while "],
  "action_template": "Analyze code for common bug patterns; output identified risks with confidence scores",
  "input_schema": {
    "code_snippet": "string",
    "context": "string (optional)"
  },
  "output_schema": {
    "bugs_found": [
      {
        "type": "string (null_check|index_error|memory_leak|race_condition|type_error|logic_error)",
        "line": "integer",
        "confidence": "float (0.0-1.0)",
        "severity": "string (low|medium|high|critical)"
      }
    ],
    "overall_confidence": "float (0.0-1.0)",
    "analysis_summary": "string"
  },
  "validation_tests": [
    {
      "input": {"code_snippet": "if items[0]: pass"},
      "expected": {"bugs_found": [{"type": "index_error", "severity": "high"}]},
      "passed": true
    },
    {
      "input": {"code_snippet": "try: x[1]\\nexcept: pass"},
      "expected": {"bugs_found": []},
      "passed": true
    },
    {
      "input": {"code_snippet": "global x\\ndef foo(): x = x + 1"},
      "expected": {"bugs_found": [{"type": "logic_error", "severity": "medium"}]},
      "passed": true
    },
    {
      "input": {"code_snippet": "for i in range(len(items)):\\n    if items[i] == target:\\n        return i\\nreturn -1"},
      "expected": {"bugs_found": []},
      "passed": true
    },
    {
      "input": {"code_snippet": "result = []\\nfor x in items:\\n    result.append(x*2)"},
      "expected": {"bugs_found": []},
      "passed": true
    }
  ],
  "metrics": {
    "pred_accuracy": 0.84,
    "precision": 0.81,
    "recall": 0.86,
    "f1_score": 0.83
  },
  "external_sources": [
    "HaPy-Bug (arxiv:2504.04810v1)",
    "Defects4J",
    "PyResBugs (github.com/dessertlab/PyResBugs)",
    "Python-Bug-Report-Dataset (github.com/soarsmu)"
  ],
  "version": "1.0",
  "created_date": "2026-03-08T09:59:00Z",
  "accuracy": 0.84
}